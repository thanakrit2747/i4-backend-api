# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามเครื่องจริง
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=i4_assessment
DB_SSL=false
PORT=3001

# origin ของหน้าเว็บที่จะเรียก API นี้ (Live Server เดิมของโปรเจกต์)
# ใส่ได้หลายค่าคั่นด้วย comma เช่น http://127.0.0.1:5500,http://localhost:5500
CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500

# ── ตอน deploy ขึ้น Render + Aiven (ดู DEPLOY-ONLINE.md) ──
# DB_HOST=<host จาก Aiven>
# DB_PORT=<port จาก Aiven>
# DB_USER=avnadmin
# DB_PASSWORD=<password จาก Aiven>
# DB_SSL=true
# CORS_ORIGIN=https://ชื่อเว็บคุณ.netlify.app
